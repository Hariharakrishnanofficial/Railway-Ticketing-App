# ─── LOCAL DEVELOPMENT ────────────────────────────────────────────────────────
# Leave VITE_API_BASE_URL blank (or commented out) during local dev.
# Axios will use the relative path '/api/' and Vite's proxy (vite.config.js)
# will forward it to the Flask backend at http://localhost:9000.
# VITE_API_BASE_URL=

# ─── PRODUCTION / CATALYST DEPLOY ────────────────────────────────────────────
# Uncomment and set this only when building for production:
# VITE_API_BASE_URL=https://railway-ticketing-system-50039510865.development.catalystappsail.in/api/

VITE_ENV=development