# Copy this file to .env and fill in your values

# ─── API BASE URL ─────────────────────────────────────────────────────────────
# For local dev: leave blank (uses Vite proxy → localhost:3002)
# For production: set to your AppSail backend URL
# VITE_API_BASE_URL=https://railway-ticketing-system-50039510865.development.catalystappsail.in/api/
VITE_API_BASE_URL=

# ─── Environment ──────────────────────────────────────────────────────────────
VITE_ENV=development

# ─── MCP Key (optional) ───────────────────────────────────────────────────────
ZOHO_MCP_KEY=